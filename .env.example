# ─── LinkedIn ────────────────────────────────────────────────────────────────
# Your LinkedIn session cookie.
# How to get it:
#   1. Log into LinkedIn in your browser
#   2. Open DevTools (F12) → Application → Cookies → https://www.linkedin.com
#   3. Copy the value of the "li_at" cookie
LINKEDIN_LI_AT_COOKIE=

# ─── Notion ──────────────────────────────────────────────────────────────────
# Your Notion integration secret token.
# How to get it:
#   1. Go to https://www.notion.so/my-integrations
#   2. Create a new integration → copy the "Internal Integration Secret"
NOTION_API_KEY=

# The ID of the Notion database to write emails into.
# How to get it:
#   1. Open your Notion database in the browser
#   2. The URL looks like: notion.so/yourworkspace/<DATABASE_ID>?v=...
#   3. Copy the 32-character DATABASE_ID (no dashes needed)
NOTION_DATABASE_ID=

# ─── Scraper settings ────────────────────────────────────────────────────────
# Number of feed scroll iterations (each scroll loads ~5-8 new posts)
MAX_SCROLL_ITERATIONS=50

# Delay range in seconds between scroll actions (min,max) — jitter avoids detection
SCROLL_DELAY_RANGE=3,7
